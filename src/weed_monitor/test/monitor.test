<launch>
  <rosparam>
    arm_workspace:
      x_min: 0.10
      x_max: 0.45
      y_min: -0.20
      y_max: 0.20
      z_min: 0.00
      z_max: 0.25
  </rosparam>
  <node pkg="weed_monitor" type="weed_monitor_node" name="weed_monitor" output="log"/>
  <test test-name="monitor_test" pkg="weed_monitor" type="weed_monitor_test"/>
</launch>
